<% if (typeof mangaList !== 'undefined' && mangaList.length > 0) { %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
        <% mangaList.forEach(manga => { %>
            <%- include('manga-card', { manga: manga }) %>
        <% }) %>
    </div>
<% } else { %>
    <div class="text-center py-20">
        <div class="text-6xl mb-4 text-gray-700">🔍</div>
        <p class="text-gray-400 text-lg">Tidak ada manga yang ditemukan. Coba kata kunci lain.</p>
    </div>
<% } %>
<!DOCTYPE html>
<html lang="id" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PuruManga - Baca Manga HTMX</title>
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        body { background-color: #0f172a; }
    </style>
</head>
<body class="text-gray-200">
    <nav class="bg-gray-900 border-b border-gray-800 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <a href="/" class="text-2xl font-bold bg-gradient-to-r from-blue-500 to-cyan-400 bg-clip-text text-transparent">
                    PuruManga
                </a>
                <div class="relative w-1/2 max-w-md">
                    <input type="text" 
                           name="q"
                           placeholder="Cari manga..." 
                           class="w-full bg-gray-800 border border-gray-700 rounded-full py-2 px-4 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm"
                           hx-get="/search"
                           hx-trigger="keyup changed delay:500ms, search"
                           hx-target="#main-content"
                           hx-indicator="#loading">
                    <div id="loading" class="htmx-indicator absolute right-3 top-2.5">
                        <svg class="animate-spin h-5 w-5 text-blue-500" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main id="main-content" class="max-w-7xl mx-auto px-4 py-8">
        <!-- Popular Section -->
        <section class="mb-12">
            <div class="flex items-center gap-2 mb-6">
                <span class="w-1 h-8 bg-blue-500 rounded"></span>
                <h2 class="text-2xl font-bold">Populer</h2>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
                <% popular.forEach(manga => { %>
                    <%- include('partials/manga-card', { manga: manga }) %>
                <% }) %>
            </div>
        </section>

        <!-- Latest Updates Section -->
        <section>
            <div class="flex items-center gap-2 mb-6">
                <span class="w-1 h-8 bg-cyan-500 rounded"></span>
                <h2 class="text-2xl font-bold">Update Terbaru</h2>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
                <% latest.forEach(manga => { %>
                    <%- include('partials/manga-card', { manga: manga }) %>
                <% }) %>
            </div>
        </section>
    </main>

    <footer class="bg-gray-900 border-t border-gray-800 py-8 mt-12 text-center text-gray-500 text-sm">
        <p>© 2024 PuruManga • Dibuat dengan HTMX & Express</p>
    </footer>
</body>
</html>
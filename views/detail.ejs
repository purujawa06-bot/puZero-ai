<!DOCTYPE html>
<html lang="id" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= manga.title %> - PuruManga</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-gray-200">
    <nav class="bg-gray-900 border-b border-gray-800 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 py-4">
            <a href="/" class="text-blue-500 hover:text-blue-400 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                </svg>
                Kembali ke Beranda
            </a>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto px-4 py-8">
        <div class="flex flex-col md:flex-row gap-8 mb-12">
            <div class="w-full md:w-1/3 flex-shrink-0">
                <img src="<%= manga.thumbnail %>" alt="<%= manga.title %>" class="w-full rounded-xl shadow-2xl border border-gray-800">
            </div>
            <div class="w-full md:w-2/3">
                <h1 class="text-3xl md:text-4xl font-bold text-white mb-2"><%= manga.title %></h1>
                <h2 class="text-xl text-gray-400 mb-4 italic"><%= manga.indo_title %></h2>
                
                <div class="flex flex-wrap gap-2 mb-6">
                    <% manga.genres.forEach(genre => { %>
                        <span class="bg-gray-800 text-gray-300 px-3 py-1 rounded-full text-xs border border-gray-700">
                            <%= genre %>
                        </span>
                    <% }) %>
                </div>

                <div class="bg-gray-900 rounded-xl p-6 border border-gray-800 mb-6">
                    <h3 class="text-lg font-semibold text-blue-400 mb-3">Sinopsis</h3>
                    <p class="text-gray-400 leading-relaxed text-sm md:text-base">
                        <%= manga.description %>
                    </p>
                </div>

                <div class="grid grid-cols-2 gap-4 text-sm">
                    <div class="text-gray-500">Status: <span class="text-gray-300"><%= manga.info.status %></span></div>
                    <div class="text-gray-500">Jenis: <span class="text-gray-300"><%= manga.info.jenis_komik %></span></div>
                    <div class="text-gray-500">Pengarang: <span class="text-gray-300"><%= manga.info.pengarang %></span></div>
                    <div class="text-gray-500">Cara Baca: <span class="text-gray-300"><%= manga.info.cara_baca %></span></div>
                </div>
            </div>
        </div>

        <section>
            <div class="flex items-center gap-2 mb-6">
                <span class="w-1 h-8 bg-blue-500 rounded"></span>
                <h2 class="text-2xl font-bold">Daftar Chapter</h2>
            </div>
            <div class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden">
                <div class="max-h-[500px] overflow-y-auto">
                    <% manga.chapters.forEach(chapter => { %>
                        <a href="/read?url=<%= encodeURIComponent(chapter.originalLink) %>" 
                           class="flex justify-between items-center p-4 hover:bg-gray-800 border-b border-gray-800 transition-colors">
                            <span class="text-gray-200 font-medium"><%= chapter.title %></span>
                            <span class="text-gray-500 text-xs"><%= chapter.date %></span>
                        </a>
                    <% }) %>
                </div>
            </div>
        </section>
    </main>

    <footer class="py-12 text-center text-gray-600 text-sm">
        <p>Data dari Komiku API • PuruManga</p>
    </footer>
</body>
</html>